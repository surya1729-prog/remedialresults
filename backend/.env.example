# MongoDB Atlas Connection URI
# Replace with your own MongoDB Atlas credentials
MONGO_URI=mongodb://username:password@cluster-name.mongodb.net:27017/database-name?ssl=true&retryWrites=true&w=majority

# Server Port
PORT=5000

# JWT Secret Key
# Use a strong random string for production
JWT_SECRET=your-secret-key-here

# Frontend URL for CORS (production deployment)
# Example: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# Environment
NODE_ENV=development
